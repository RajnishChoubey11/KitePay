generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  COMPANY
  EMPLOYEE
}

enum PayoutMethod {
  CRYPTO
  BANK
}

model User {
  id            String        @id @default(uuid())
  name          String?
  email         String        @unique
  password      String?
  role          Role
  companyName   String?
  walletAddress String?
  payoutMethod  PayoutMethod?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model PayrollRun {
  id          String   @id @default(uuid())
  employerId  String
  createdAt   DateTime @default(now())
  status      String   @default("PENDING")
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String?
  txHash      String?
  type        String
  amount      Float
  status      String   @default("PENDING")
  createdAt   DateTime @default(now())
}